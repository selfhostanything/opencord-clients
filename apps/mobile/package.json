{
  "name": "mobile",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "main": "index.js",
  "scripts": {
    "start": "react-native start --port ${RCT_METRO_PORT:-8088}",
    "android": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} PATH=${ANDROID_HOME:-$HOME/Library/Android/sdk}/emulator:${ANDROID_HOME:-$HOME/Library/Android/sdk}/platform-tools:$PATH react-native run-android --no-packager --port ${RCT_METRO_PORT:-8088}",
    "android:build": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} PATH=${ANDROID_HOME:-$HOME/Library/Android/sdk}/emulator:${ANDROID_HOME:-$HOME/Library/Android/sdk}/platform-tools:$PATH sh -c 'cd android && ./gradlew assembleDebug'",
    "android:devices": "ANDROID_HOME=${ANDROID_HOME:-$HOME/Library/Android/sdk} PATH=${ANDROID_HOME:-$HOME/Library/Android/sdk}/platform-tools:$PATH adb devices",
    "ios": "react-native run-ios",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "private": true,
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@opencord/api-client": "workspace:*",
    "@opencord/realtime": "workspace:*",
    "@opencord/server-connections": "workspace:*",
    "react": "^19.2.7",
    "react-native": "^0.86.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/gradle-plugin": "0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@types/react": "^19.2.17",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
